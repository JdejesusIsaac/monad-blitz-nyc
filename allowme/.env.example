# SQLite database (relative to allowme/)
DATABASE_URL=file:./allowme.db

# OWS — local vault on VPS (see scripts/setup-ows.sh)
OWS_VAULT_PATH=/secure/.ows
OWS_TREASURY_WALLET=nypl-treasury

# Agent credentials are NOT set here. After POST /api/treasury/setup they live at:
#   $OWS_VAULT_PATH/reward-agent.token  (chmod 600)

# Optional: override Monad testnet RPC
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
